#include <iostream> 
#include <string>

using namespace std;

bool hasLetter(string row, int size) {
	char letters[12] = { 'a', 'A', 'o', 'O', 'u', 'U', 'e', 'E', 'y', 'Y', 'i', 'I' };
	bool result = false;

	for (int i = 0; i < 12; i++) {
	
		for (int j = 0; j < size; j++) {
		
			if (row[j] == letters[i]) {
			
				return result = true;
			
			}
		
		}
	
	}

	return result;

}

int main() {


	string S;

	cout << "Enter something:";
	getline(cin, S);


	for (int i = 0; i < S.length(); i++) {
	
		if (hasLetter(S, S.length())) {
			
			S.insert(i + 1, 1, S[i]);
		
		}
	
	}

	cout << "Changed row:" << S;

	return 0;
}
